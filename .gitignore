# Node modules (NEVER commit)
node_modules/
client/node_modules/
server/node_modules/
*/node_modules/
**/node_modules/

# Environment variables (SECRETS - CRITICAL)
.env
.env.local
.env.*.local
.env.production
.env.development
client/.env
client/.env.local
server/.env
server/.env.local
*.env
!.env.example

