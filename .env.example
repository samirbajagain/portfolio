# ════════════════════════════════════════════════════════════════════════════════
# Environment Configuration Example
# ════════════════════════════════════════════════════════════════════════════════
# DO NOT commit actual .env file with secrets!
# Copy this file to .env and fill in your values locally.
# ════════════════════════════════════════════════════════════════════════════════

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Server Configuration
PORT=5000
NODE_ENV=development

# Client Configuration (used during build)
VITE_API_BASE_URL=http://localhost:5000

# GitHub Pages Configuration (for static deployment)
VITE_IS_STATIC=false
